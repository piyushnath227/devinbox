APP_NAME=DevInbox
DEBUG=false
HOST=0.0.0.0
PORT=8000
SECRET_KEY=change-this-to-a-random-secret-key
DATABASE_URL=sqlite:///./data/devinbox.db
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
QWEN_MAX_TOKENS=4096
QWEN_TEMPERATURE=0.2
KEYS_DIR=./data/keys

# If set, issue-processing jobs go through a persistent Redis+RQ queue
# (survives restarts, scales across multiple servers) -- run `python
# worker.py` as a separate process/container to consume it. If left blank,
# DevInbox falls back to a simple in-process queue, fine for local dev but
# jobs are lost on restart. See docker-compose.yml for the Redis + worker
# service setup.
REDIS_URL=
MAX_CONCURRENT_JOBS=2
MAX_JOBS_PER_MINUTE=20

# Comma-separated list of origins allowed to make cross-origin requests to
# the API. Leave blank unless something outside the dashboard itself needs
# cross-origin access (e.g. https://example.com,https://app.example.com).
CORS_ALLOWED_ORIGINS=
